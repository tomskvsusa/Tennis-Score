{
  "name": "brainstorm",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspace @brainstorm/core",
    "dev:web": "npm run dev --workspace @brainstorm/web",
    "cli": "npm run build --workspace @brainstorm/core && npm run build --workspace @brainstorm/cli && npm run start --workspace @brainstorm/cli"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
